#:kivy 2.2.0

#:import MainAppBar src.front.components.app_bar.MainAppBar
#:import ScreenTitle src.front.components.app_bar.ScreenTitle

<BeaconsMobileView>:
    name: "beacons_mobile_view"

<BeaconsTabletView>:
    name: "beacons_tablet_view"

    MDBoxLayout:
        orientation: "vertical"

        MainAppBar:

        ScreenTitle:
            title: "Beacons - Configuration"
            left_action_items: [["arrow-left", lambda x: app.root.ids.screen_manager.get_screen("beacons").go_back()]]
            
        MDBoxLayout:
            id: content_layout
            orientation: "vertical"
            size_hint_y: None
            height: root.height - 2 * dp(64) #dp(64) = MDTopAppBar height

            MDBoxLayout:
                size_hint_y: None
                height: content_layout.height * 0.6
            
            MDGridLayout:
                cols: 3
                padding: dp(10), 0, dp(10), 0
                spacing: dp(10)
                
                Input:
                    hint_text: "P1 - P2 [m]"
                    input_filter: "float"
                    helper_text_mode: "on_error"

                Input:
                    hint_text: "P2 - P3 [m]"
                    input_filter: "float"
                    helper_text_mode: "on_error"

                Input:
                    hint_text: "P3 - P4 [m]"
                    input_filter: "float"
                    helper_text_mode: "on_error"

                Input:
                    hint_text: "P4 - P1 [m]"
                    input_filter: "float"
                    helper_text_mode: "on_error"

                Input:
                    hint_text: "P1 - P3 [m]"
                    input_filter: "float"
                    helper_text_mode: "on_error"

                Input:
                    hint_text: "P2 - P4 [m]"
                    input_filter: "float"
                    helper_text_mode: "on_error"

            MDBoxLayout:
                id: control_button
                padding: dp(10)
                spacing: dp(10)
                adaptive_size: True
                pos_hint: {"center_y": 0.5, "right": 1}

                MDFillRoundFlatButton:
                    text: "Validate"
                    font_style: "Button"

<BeaconsDesktopView>:
    name: "beacons_desktop_view"