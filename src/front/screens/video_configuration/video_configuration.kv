#:kivy 2.2.0

#:import TextUnderIconButton src.front.components.widget.TextUnderIconButton
#:import DefaultScreenTopBar src.front.components.app_bar.DefaultScreenTopBar

<VideoConfigurationMobileView>:
    name: "video_configuration_mobile_view"

    MDBoxLayout:
        orientation: "vertical"

        DefaultScreenTopBar:
            title: "Video - Configuration"
   
        VideoUpload:
            id: video_upload
            type: "tablet" 
        
        MDScrollView:
            do_scroll_x: False
            do_scroll_y: True

            MDGridLayout:
                cols: 1
                spacing: 0
                size_hint: 1, 1.3
                pos_hint: {"center_x": .5}

                MDBoxLayout:
                    padding: dp(10)
                    spacing: dp(10)

                    StartTimeInput:
                        id: start_time
                        input_filter: "float"

                MDBoxLayout:
                    padding: dp(10)
                    spacing: dp(10)

                    EndTimeInput:
                        id: end_time
                        input_filter: "float"
                
                MDBoxLayout:
                    padding: dp(10)
                    spacing: dp(10)

                    FrequencyInput:
                        id: frequency
                        input_filter: "int"

                MDBoxLayout:

                    MDBoxLayout:
                        pos_hint: {"center_y": 0.5, "right": 1}

                    VideoConfigurationBottomButtons:
                        id: bottom_buttons

<VideoConfigurationTabletView>:
    name: "video_configuration_tablet_view"

    MDBoxLayout:
        orientation: "vertical"

        DefaultScreenTopBar:
            title: "Video - Configuration"
            left_action_items: [["arrow-left", lambda x: app.root.ids.screen_manager.get_screen("video_configuration").go_back()]]

        VideoUpload:
            id: video_upload
            type: "tablet" 
        
        MDBoxLayout:
            orientation: "vertical"
            spacing: 0
            size_hint_x: 0.85
            pos_hint: {"center_x": .5}

            MDBoxLayout:
                padding: dp(10)
                spacing: dp(10)

                StartTimeInput:
                    id: start_time
                    input_filter: "float"

                EndTimeInput:
                    id: end_time
                    input_filter: "float"

            MDBoxLayout:
                padding: dp(10)
                spacing: dp(10)

                FrequencyInput:
                    id: frequency
                    input_filter: "int"

        VideoConfigurationBottomButtons:
            id: bottom_buttons

<VideoConfigurationDesktopView>:
    name: "video_configuration_desktop_view"

    MDBoxLayout:
        orientation: "vertical"

        DefaultScreenTopBar:
            title: "Video - Configuration"

        VideoUpload:
            id: video_upload
            type: "tablet" 
        
        MDBoxLayout:
            orientation: "vertical"
            spacing: 0
            size_hint_x: 0.85
            pos_hint: {"center_x": .5}

            MDBoxLayout:
                padding: dp(10)
                spacing: dp(10)

                StartTimeInput:
                    id: start_time
                    input_filter: "float"

                EndTimeInput:
                    id: end_time
                    input_filter: "float"

            MDBoxLayout:
                padding: dp(10)
                spacing: dp(10)

                FrequencyInput:
                    id: frequency
                    input_filter: "int"

        VideoConfigurationBottomButtons:
            id: bottom_buttons

<VideoUpload@MDGridLayout>:
    cols: 2
    type: "desktop"
    disabled: False

    MDBoxLayout:
        padding: 
            (dp(100), dp(10), dp(10), dp(10)) if root.type == "desktop" else \
            (dp(65), dp(10), dp(10), dp(10)) if root.type == "tablet" else \
            dp(15) if root.type == "mobile" else \
            None
        size_hint: .7,.7
        pos_hint: {'center_y':0.5}

        TextUnderIconButton:
            disabled: root.disabled
            icon: "upload"
            icon_size: "64sp"
            text: "Upload Video"
            on_release: app.root.ids.screen_manager.get_screen("video_configuration").open_file_manager()
        
    MDBoxLayout:
        padding: 
            (dp(10), dp(10), dp(100), dp(10)) if root.type == "desktop" else \
            (dp(10), dp(10), dp(65), dp(10)) if root.type == "tablet" else \
            dp(15) if root.type == "mobile" else \
            None
        size_hint: .7,.7
        pos_hint: {'center_y':0.5}

        TextUnderIconButton:
            disabled: True
            icon: "video"
            icon_size: "64sp"
            text: "Record Video"
            
<VideoConfTextInput@MDTextField>:
    mode: "rectangle"
    line_color_normal: app.theme_cls.primary_color
    text_color_normal: app.theme_cls.primary_color


<StartTimeInput@MDTextField>:
    mode: "rectangle"
    line_color_normal: app.theme_cls.primary_color
    text_color_normal: app.theme_cls.primary_color
    hint_text: "Start Time [s]"
    helper_text_mode: "on_error"
    on_focus: app.root.ids.screen_manager.get_screen("video_configuration").set_start_time(self.text) if not self.focus else None

<EndTimeInput@MDTextField>:
    mode: "rectangle"
    line_color_normal: app.theme_cls.primary_color
    text_color_normal: app.theme_cls.primary_color
    hint_text: "End Time [s]"
    helper_text_mode: "on_error"
    on_focus: app.root.ids.screen_manager.get_screen("video_configuration").set_end_time(self.text) if not self.focus else None

<FrequencyInput@MDTextField>:
    mode: "rectangle"
    line_color_normal: app.theme_cls.primary_color
    text_color_normal: app.theme_cls.primary_color
    hint_text: "Frequency [frame / s]"
    helper_text_mode: "on_error"
    on_focus: app.root.ids.screen_manager.get_screen("video_configuration").set_frequency(self.text) if not self.focus else None

<VideoConfigurationBottomButtons@MDBoxLayout>:
    padding: dp(10)
    spacing: dp(10)
    adaptive_size: True
    pos_hint: {"center_y": 0.5, "right": 1}
    remove_is_disabled : True

    MDFillRoundFlatButton:
        text: "Change Video"
        font_style: "Button"
        disabled: root.remove_is_disabled
        md_bg_color: app.theme_cls.error_color
        on_release: app.root.ids.screen_manager.get_screen("video_configuration").remove_video()

    MDFillRoundFlatButton:
        text: "Validate"
        font_style: "Button"
        on_release: app.root.ids.screen_manager.get_screen("video_configuration").validate_video_configuration()