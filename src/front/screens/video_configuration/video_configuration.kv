#:kivy 2.2.0

#:import MainAppBar src.front.components.app_bar.MainAppBar
#:import ScreenTitle src.front.components.app_bar.ScreenTitle
#:import TextUnderIconButton src.front.components.widget.TextUnderIconButton

<VideoConfigurationMobileView>:
    name: "video_configuration_mobile_view"

    MDBoxLayout:
        orientation: "vertical"

        MainAppBar:

        ScreenTitle:
            title: "Video - Configuration"
            
        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: root.height - 2 * dp(64) #dp(64) = MDTopAppBar height
            
            VideoUpload:
                id: video_upload
                type: "mobile"
                
            MDScrollView:
                do_scroll_x: False
                do_scroll_y: True

                MDGridLayout:
                    cols: 1
                    spacing: 0
                    size_hint: 1, 1.3
                    pos_hint: {"center_x": .5}

                    MDBoxLayout:
                        padding: dp(10)
                        spacing: dp(10)

                        VideoConfTextInput:
                            id: start_time_input
                            hint_text: "Start Time [s]"
                            input_filter: "float"
                            helper_text_mode: "on_error"
                            on_focus: app.root.ids.screen_manager.get_screen("video_configuration").set_start_time(self.text) if not self.focus else None
                            text: "0"

                    MDBoxLayout:
                        padding: dp(10)
                        spacing: dp(10)
                        
                        VideoConfTextInput:
                            id: end_time_input
                            hint_text: "End Time [s]"
                            input_filter: "float"
                            helper_text_mode: "on_error"
                            on_focus: app.root.ids.screen_manager.get_screen("video_configuration").set_end_time(self.text) if not self.focus else None
                            text: "1"

                            
                    MDBoxLayout:
                        padding: dp(10)
                        spacing: dp(10)

                        VideoConfTextInput:
                            id: frequency_input
                            hint_text: "Frequency [frame / s]"
                            input_filter: "int"
                            helper_text_mode: "on_error"
                            on_focus: app.root.ids.screen_manager.get_screen("video_configuration").set_frequency(self.text) if not self.focus else None
                            text:"1"
                    
                    MDBoxLayout:
                        padding: dp(10)
                        spacing: dp(10)
                        
                        MDBoxLayout:
                            pos_hint: {"center_y": 0.5, "right": 1}
                        
                        MDFillRoundFlatButton:
                            id: remove_video
                            text: "Change Video"
                            font_style: "Button"
                            disabled: True
                            md_bg_color: app.theme_cls.error_color
                            on_release: app.root.ids.screen_manager.get_screen("video_configuration").remove_video()

                        MDFillRoundFlatButton:
                            text: "Validate"
                            font_style: "Button"
                            on_release: app.root.ids.screen_manager.get_screen("video_configuration").send_video_configuration()

<VideoConfigurationTabletView>:
    name: "video_configuration_tablet_view"

    MDBoxLayout:
        orientation: "vertical"

        MainAppBar:

        ScreenTitle:
            title: "Video - Configuration"

        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: root.height - 2 * dp(64) #dp(64) = MDTopAppBar height

            VideoUpload:
                id: video_upload
                type: "tablet" 
                                      
            MDBoxLayout:
                orientation: "vertical"
                spacing: 0
                size_hint_x: 0.85
                pos_hint: {"center_x": .5}

                MDBoxLayout:
                    padding: dp(10)
                    spacing: dp(10)

                    VideoConfTextInput:
                        id: start_time_input
                        hint_text: "Start Time [s]"
                        input_filter: "float"
                        helper_text_mode: "on_error"
                        on_focus: app.root.ids.screen_manager.get_screen("video_configuration").set_start_time(self.text) if not self.focus else None
                        text: "0"

                    VideoConfTextInput:
                        id: end_time_input
                        hint_text: "End Time [s]"
                        input_filter: "float"
                        helper_text_mode: "on_error"
                        on_focus: app.root.ids.screen_manager.get_screen("video_configuration").set_end_time(self.text) if not self.focus else None
                        text: "1"

                MDBoxLayout:
                    padding: dp(10)
                    spacing: dp(10)

                    VideoConfTextInput:
                        id: frequency_input
                        hint_text: "Frequency [frame / s]"
                        input_filter: "int"
                        helper_text_mode: "on_error"
                        on_focus: app.root.ids.screen_manager.get_screen("video_configuration").set_frequency(self.text) if not self.focus else None
                        text:"1"
                
                MDBoxLayout:
                    padding: dp(10)
                    spacing: dp(10)
                    adaptive_size: True
                    pos_hint: {"center_y": 0.5, "right": 1}

                    MDFillRoundFlatButton:
                        id: remove_video
                        text: "Change Video"
                        font_style: "Button"
                        disabled: True
                        md_bg_color: app.theme_cls.error_color
                        on_release: app.root.ids.screen_manager.get_screen("video_configuration").remove_video()

                    MDFillRoundFlatButton:
                        text: "Validate"
                        font_style: "Button"
                        on_release: app.root.ids.screen_manager.get_screen("video_configuration").send_video_configuration()
                        

<VideoConfigurationDesktopView>:
    name: "video_configuration_desktop_view"

    MDBoxLayout:
        orientation: "vertical"

        MainAppBar:

        ScreenTitle:
            title: "Video - Configuration"
            
        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: root.height - 2 * dp(64) #dp(64) = MDTopAppBar height
            
            VideoUpload:
                id: video_upload
                type: "desktop"
                            
            MDBoxLayout:
                orientation: "vertical"
                spacing: 0
                size_hint_x: 0.85
                pos_hint: {"center_x": .5}

                MDBoxLayout:
                    padding: dp(10)
                    spacing: dp(10)

                    VideoConfTextInput:
                        id: start_time_input
                        hint_text: "Start Time [s]"
                        input_filter: "float"
                        helper_text_mode: "on_error"
                        on_focus: app.root.ids.screen_manager.get_screen("video_configuration").set_start_time(self.text) if not self.focus else None
                        text:"0"
                    
                    VideoConfTextInput:
                        id: end_time_input
                        hint_text: "End Time [s]"
                        input_filter: "float"
                        helper_text_mode: "on_error"
                        on_focus: app.root.ids.screen_manager.get_screen("video_configuration").set_end_time(self.text) if not self.focus else None
                        text:"1"

                MDBoxLayout:
                    padding: dp(10)
                    spacing: dp(10)

                    VideoConfTextInput:
                        id: frequency_input
                        hint_text: "Frequency [frame / s]"
                        input_filter: "int"
                        helper_text_mode: "on_error"
                        on_focus: app.root.ids.screen_manager.get_screen("video_configuration").set_frequency(self.text) if not self.focus else None
                        text:"1"

                MDBoxLayout:
