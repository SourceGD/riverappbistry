#:kivy 2.2.0

#:import DefaultScreenTopBar src.front.components.app_bar.DefaultScreenTopBar

<PostProcessMobileView>:

<PostProcessTabletView>:
    name: "post_process_tablet_view"

    MDBoxLayout:
        orientation: "vertical"

        DefaultScreenTopBar:
            title: "Post processing"


        MDRelativeLayout:

            MDFillRoundFlatButton:
                pos_hint: {"top" : 0.85, "center_x" : 0.5}
                text: "Display transects"
                font_style: "Button"
                md_bg_color: app.theme_cls.error_color
                on_release: app.root.ids.screen_manager.get_screen("post_process").on_button_press()

<PostProcessDesktopView>: