#:kivy 2.2.0

#:import MainAppBar src.front.components.app_bar.MainAppBar
#:import ScreenTitle src.front.components.app_bar.ScreenTitle
#:import TextUnderIconButton src.front.components.widget.TextUnderIconButton
#:import DefaultScreenTopBar src.front.components.app_bar.DefaultScreenTopBar

<BathymetryMobileView>:
    name: "bathymetry_mobile_view"

    MDBoxLayout:
        orientation: "vertical"

        DefaultScreenTopBar:
            title: "Bathymetry - Configuration"
            left_action_items: [["arrow-left", lambda x: app.root.ids.screen_manager.get_screen("bathymetry").go_back()]]
            
        MDBoxLayout:
            id: content

            UploadBathy:
                id: upload_button
                type: "mobile"

        BathymetryBottomButtons:
            id: control_button

<BathymetryTabletView>:
    name: "bathymetry_tablet_view"

    MDBoxLayout:
        orientation: "vertical"

        DefaultScreenTopBar:
            title: "Bathymetry - Configuration"
            left_action_items: [["arrow-left", lambda x: app.root.ids.screen_manager.get_screen("bathymetry").go_back()]]
            
        MDBoxLayout:
            id: content

            UploadBathy:
                id: upload_button
                type: "tablet"

        BathymetryBottomButtons:
            id: control_button

<BathymetryDesktopView>:
    name: "bathymetry_desktop_view"

    MDBoxLayout:
        orientation: "vertical"

        DefaultScreenTopBar:
            title: "Bathymetry - Configuration"
            left_action_items: [["arrow-left", lambda x: app.root.ids.screen_manager.get_screen("bathymetry").go_back()]]
            
        MDBoxLayout:
            id: content

            UploadBathy:
                id: upload_button
                type: "desktop"

        BathymetryBottomButtons:
            id: control_button

<Input@MDTextField>:
    mode: "rectangle"
    line_color_normal: app.theme_cls.primary_color
    text_color_normal: app.theme_cls.primary_color

<UploadBathy@MDBoxLayout>:
    type: "desktop"

    # Empty FloatLayout because if button is alone in a Layout the width strech to maximum
    MDFloatLayout:
        size_hint: 
            (0.9, 1) if root.type == "desktop" else \
            (0.7, 1) if root.type == "tablet" else \
            (0.2, 1) if root.type == "mobile" else \
            (None, None)

    TextUnderIconButton:
        size_hint: 1, 0.5
        pos_hint: {"center_x": 0.5, "center_y": 0.5}
        icon: "upload"
        icon_size: "64sp"
        text: "Upload Bathymetry"
        on_release: app.root.ids.screen_manager.get_screen("bathymetry").open_file_manager()
        
    # Empty FloatLayout because if button is alone in a Layout the width stech to maximum
    MDFloatLayout:
        size_hint: 
            (0.9, 1) if root.type == "desktop" else \
            (0.7, 1) if root.type == "tablet" else \
            (0.2, 1) if root.type == "mobile" else \
            (None, None)

<BathymetryBottomButtons@MDBoxLayout>:
    padding: dp(10)
    spacing: dp(10)
    adaptive_size: True
    pos_hint: {"center_y": 0.5, "right": 1}
    disabled: True
    opacity: 0 if self.disabled else 1

    MDFillRoundFlatButton:
        text: "Change Bathymetry"
        font_style: "Button"
        disabled: root.disabled
        md_bg_color: app.theme_cls.error_color
        on_release: app.root.ids.screen_manager.get_screen("bathymetry").remove_graph()

    MDFillRoundFlatButton:

        text: "Validate"
        font_style: "Button"
        disabled: root.disabled
        on_release: app.root.ids.screen_manager.get_screen("bathymetry").send_bathymetry()