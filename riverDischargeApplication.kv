<PIVPopup>:
    title: 'Parameters for PIV analysis'
    title_size: '20dp'
    size_hint: None, None
    size: 500, 350
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        GridLayout:
            cols:2
            Label:
                text: 'Interrogation window size:\nIn pixels. '
            TextInput:
                id: InWindSizeID
                multiline: False
                text: '32'
            Label:
                text: 'Overlap in pixels: \nGenerally 50%'
            TextInput:
                id:OverlapID
                multiline: False
                text: '16'
            Label:
                text: 'SNR ratio for validation: '
            TextInput:
                id: SNRID
                multiline: False
                text: '2'
        GridLayout:
            cols:2
            size_hint_y: None
            height: self.parent.height*(1/6)
            Button:
                text: 'Cancel'
                on_release: 
                    app.root.current = 'FiltersScreen'
                    on_release: root.dismiss()
            Button:
                text: 'Load'
                on_release: 
                    # root.launchThread(int(InWindSizeID.text),int(SearchWindSizeID.text),int(OverlapID.text))
                    root.launchThread(int(InWindSizeID.text),int(OverlapID.text),float(SNRID.text))
                    
                    root.dismiss()
                    # app.root.current = 'surfaceVelocityScreen'
                    # app.root.current = 'FiltersScreen'
                    
