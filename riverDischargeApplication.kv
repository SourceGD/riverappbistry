<Filters>:
    name: 'FiltersScreen'
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        canvas.before:
            Color:
                rgba: 51/255, 51/255, 61/255, 1
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: 'Filters application'
            font_size: '50sp'
            size_hint_y: None
            size: 0, root.size[1]/9
            canvas.before:
                Color:
                    rgba: 0,0,0,1
                Rectangle:
                    pos: self.pos
                    size: self.size
        BoxLayout:
            id: filterGraphID
            # size_hint_y: None
        GridLayout:
            cols:8
            size_hint_y: None
            height: self.parent.height*(1/10)
            Button:
                text: 'Go back'
                on_release: 
                    app.root.current = 'MaskAndROIScreen'
            Spinner:
                id: spinID
                text: 'Choice Filter'
                values: 'CLAHE', 'Intensity Capping', 'Intensity high-pass', 'Mean Denoising', 'Contrast/Brightness', 'Gamma correction'
            Button:
                text: 'Information'
                on_release: 
                    if (spinID.text == 'CLAHE'): p = Factory.CLAHEInformation();p.open()
                    elif(spinID.text == 'Intensity Capping'): p = Factory.IntensityCappingInformation();p.open()
                    elif(spinID.text =='Intensity high-pass'): p = Factory.IntensityHighPassInformation();p.open()
                    elif(spinID.text =='Mean Denoising'): p = Factory.MeanDenoisingInformation();p.open()
                    elif(spinID.text =='Contrast/Brightness'): p = Factory.ContrastBrightnessInformation();p.open()
                    elif(spinID.text =='Gamma correction'): p = Factory.GammaCorrectionInformation();p.open()
            Button:
                text: 'Apply'
                on_release: 
                    if (spinID.text == 'CLAHE'): p = Factory.CLAHEPopup(selectFilter=root.selectFilter);p.open()
                    elif(spinID.text == 'Intensity Capping'): p = Factory.IntensityCappingPopup(selectFilter=root.selectFilter,findParamIntCapping=root.findParamIntCapping);p.open()
                    elif(spinID.text =='Intensity high-pass'):p = Factory.IntensityHighPassPopup(selectFilter=root.selectFilter, findParamHighPass= root.findParamHighPass);p.open()
                    elif(spinID.text =='Mean Denoising'):p = Factory.MeanDenoisingPopup(selectFilter=root.selectFilter);p.open()
                    elif(spinID.text =='Contrast/Brightness'):p = Factory.ContrastBrightnessPopup(selectFilter=root.selectFilter);p.open()
                    elif(spinID.text =='Gamma correction'):p = Factory.GammaCorrectionPopup(selectFilter=root.selectFilter);p.open()
            
            Button:
                text: 'Add'
                on_release: 
                    if (spinID.text == 'CLAHE'): root.registerFilter(spinID.text); p = Factory.FilterApplied();p.open()
                    elif(spinID.text == 'Intensity Capping'):root.registerFilter(spinID.text); p = Factory.FilterApplied();p.open()
                    elif(spinID.text =='Intensity high-pass'):root.registerFilter(spinID.text); p = Factory.FilterApplied();p.open()
                    elif(spinID.text =='Mean Denoising'):root.registerFilter(spinID.text); p = Factory.FilterApplied();p.open()
                    elif(spinID.text =='Contrast/Brightness'):root.registerFilter(spinID.text); p = Factory.FilterApplied();p.open()
                    elif(spinID.text =='Gamma correction'):root.registerFilter(spinID.text); p = Factory.FilterApplied();p.open()
                    else : p = Factory.FilterNotFound();p.open()
            Button:
                text: 'Remove'
                on_release: 
                    root.removeFilter()
            Button:
                text: 'Histogram'
                on_release: 
                    #root.saveFilterChosen()
                    root.plotHistogram(app.VIDEOFILEPATH)
            Button:
                text:'Load'
                on_release:
                    root.saveFilterChosen()
                    app.root.current = 'PIVAnalysisScreen'
                    
