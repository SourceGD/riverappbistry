<LoadingDistOrthoPopup>:
    title: 'Load real distances bewteen reference points'
    title_size: '20dp'
    size_hint: None, None
    size: 500, 600
    auto_dismiss: False
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        GridLayout:
            size_hint_y: None
            height: self.parent.height*(1/6)
            spacing: ('0sp','5sp')
            cols:2
            Label:
                text: 'Distances in meter: '
            TextInput:
                id: distancesID
                multiline: False
                hint_text: 'L1, L2, L3, L4, L5, L6'
        Image:
            source: 'image/distances.png'
        GridLayout:
            cols: 2
            size_hint_y: None
            height: self.parent.height*(1/10)
            Button:
                font_size: '20sp'
                text: 'Cancel'
                on_release: root.dismiss()
            Button:
                font_size: '20sp'
                text: 'Load'
                on_release: 
                    if (distancesID.text == ''): p = Factory.DistancesNotFound(); p.open()
                    else :  root.SetRealDistances([float(elt) for elt in distancesID.text.split(',')]);root.dismiss()
                    
