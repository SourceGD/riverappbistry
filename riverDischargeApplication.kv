                on_release: 
                    if (not calibrationFileID.selection): p = Factory.FileNotFound();p.open()
                    else : root.loadFile(calibrationFileID.selection); root.dismiss(); app.root.current = 'OrthoRectificationScreen'
                    #root.loadFile(calibrationFileID.selection)
                    
<ComputationCalibPopup>:
    title: 'Calibration parameters'
    title_size: '20dp'
    size_hint: None, None
    size: 800, 600
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        GridLayout:
            cols:2
            size_hint_y: None
            height: self.parent.height*(1/3)
            Label:
                text: 'Select video file for calibration'
            FileChooserListView:
                id: calibrationVideoID
                path: os.getcwd()
        GridLayout:
            cols:2
            Label:
                text: 'Name of the file that will \n contain calibration parameters:'
            TextInput:
                id: nameFileID
                hint_text: 'e.g. : calibration_parameters'
            Label:
                text: 'Dimensions of the board :'
            TextInput:
                id: dimBoardID
                hint_text: 'e.g. : 4,6'
            Label:
                text: 'Number of image you\nwant to extract :'
            TextInput:
                id: nbrImgID
                hint_text: 'e.g. : 30'
            Label:
                text: 'Size of the square of\nthe chessboard in mm :'
            TextInput:
                id: sizeSquareID
                hint_text: 'e.g. : 40'
        GridLayout:
            cols: 2
            size_hint_y: None
            height: self.parent.height*(1/4)
            Button:
                font_size: '20sp'
                text: 'Go back'
                on_release: root.dismiss()
            Button:
                font_size: '20sp'
                text: 'Load'
                on_release: 
                    if (not calibrationVideoID.selection): p= Factory.FileNotFound();p.open()
                    elif (nameFileID.text == ''): p=Factory.ValueNotFound();p.open()
                    elif (dimBoardID.text ==''): p=Factory.ValueNotFound();p.open()
                    elif (nbrImgID.text ==''): p=Factory.ValueNotFound();p.open()
                    elif (sizeSquareID.text ==''): p=Factory.ValueNotFound();p.open()
                    else: root.computeCalib(nameFileID.text, calibrationVideoID.selection, dimBoardID.text, sizeSquareID.text, nbrImgID.text); root.dismiss(); app.root.current = 'OrthoRectificationScreen'
<LoadingParamCalibPopup>:
    title: 'Calibration parameters'
    title_size: '20dp'
    size_hint: None, None
    size: 800, 600
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        GridLayout:
            cols:2
            Label:
                text: 'Name of the file that will \n contain calibration parameters:'
            TextInput:
                id: nameFileID
                hint_text: 'e.g. : calibration_parameters'
            Label:
                text: 'Coefficients of distortion :'
            TextInput:
                id: distCoeffsID
                hint_text: 'e.g. : 4,6,8,12'
            Label:
                text: 'c_x (optical center):'
            TextInput:
                id: cxID
                hint_text: 'e.g. : 0'   
            Label:
                text: 'c_y (optical center):'
            TextInput:
                id: cyID
                hint_text: 'e.g. : 0' 
            Label:
                text: 'Horizontal focal distance :'
            TextInput:
                id: fovxID
                hint_text: 'e.g. : 200'
            Label:
                text: 'Vertical focal distance :'
            TextInput:
                id: fovyID
                hint_text: 'e.g. : 200'
            Label:
                text: 'Diagonal focal distance :'
            TextInput:
                id: fovdiagID
                hint_text: 'e.g. : 200'
        GridLayout:
            cols: 2
            size_hint_y: None
            height: self.parent.height*(1/8)
            Button:
                font_size: '20sp'
                text: 'Go back'
                on_release: root.dismiss()
            Button:
                font_size: '20sp'
                text: 'Load'
                on_release:
                    if (nameFileID.text == ''): p=Factory.ValueNotFound();p.open()
                    elif (distCoeffsID.text ==''): p=Factory.ValueNotFound();p.open()
                    elif (cxID.text ==''): p=Factory.ValueNotFound();p.open()
                    elif (cyID.text ==''): p=Factory.ValueNotFound();p.open()
                    elif (fovxID.text ==''): p=Factory.ValueNotFound();p.open()
                    elif (fovyID.text ==''): p=Factory.ValueNotFound();p.open()
                    else : root.loadParam(nameFileID.text, distCoeffsID.text, cxID.text, cyID.text, fovxID.text, fovyID.text, fovdiagID.text); root.dismiss(); app.root.current = 'OrthoRectificationScreen'

<Bathymetry>:
    name: 'bathStartScreen'
