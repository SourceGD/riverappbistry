#:kivy 1.11
#:import Factory kivy.factory.Factory
#:import FileChooserListView kivy.uix.filechooser
#:import LinePlot kivy.garden.graph.LinePlot
#:import os os
#:import cv2 cv2
#:import TextInput kivy.uix.textinput

WindowManager:
    Bathymetry:
    BathymetryLoad:
    BathymetryCreate:
    LoadingVideo:
    Calibration:
    OrthoRectification:
    WaterLevel:
    WaterLevelOrtho:
    WaterLevelDEM:
    WaterLevelComputation:
    ROIMASK:
    Filters:
    PIVAnalysis:
    SurfaceVelocity:
    SurfaceVelocityMultiPass:
    SectionOfInterest:
    RetrievSectionVelocityVectors:
    DischargeComputation:

<CustomButton@Button>:
    font_size: '40sp'
    size_hint: 0.3,0.05
    pos_hint: {'center_x': 0.5}

<CustomPopup@Popup>:
    title: 'Loading Bathymetry Text File'
    title_size: '20dp'
    size_hint: None, None
    size: 500, 300
    auto_dismiss: False
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        FileChooserListView:
            id: filechooser
            path: os.getcwd() + '/sections' + '/files'
        GridLayout:
            cols: 2
            size_hint_y: None
            height: self.parent.height*(1/4)
            Button:
                text: 'Cancel'
                on_release: root.dismiss()
            Button:
                text: 'Load'
                # on_release: print('ok')
                on_release: 
                    if (not filechooser.selection) : p = Factory.FileNotFound();p.open()
                    else : app.BATHFILEPATH = filechooser.selection[0];root.dismiss();app.root.current = 'bathLoadScreen'
                    #root.loadFileSelected(filechooser.selection)
<FileNotFound>
    title: 'File not found'
    title_size: '20dp'
    size_hint: None, None
    size: 350, 200
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        GridLayout:
            size_hint_y: None
            height: self.parent.height*0.6
            cols:1
            Label: 
                text: 'You did not select any file.'
        Button:
            size_hint_y: None
            height: self.parent.height*0.4
            text: 'Select a file'
            on_release: 
                root.dismiss()
<ValueNotFound>
    title: 'Value(s) not found'
    title_size: '20dp'
    size_hint: None, None
    size: 350, 200
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        GridLayout:
            size_hint_y: None
            height: self.parent.height*0.6
            cols:1
            Label: 
                text: 'You did not write all the values.'
        Button:
            size_hint_y: None
            height: self.parent.height*0.4
            text: 'Try again'
            on_release: 
                root.dismiss()
                        
<CreateBathPopup>:
    title: 'Bathymetry Parameters'
    title_size: '20dp'
    size_hint: None, None
    size: 600, 600
    auto_dismiss: False
    GridLayout:
        id: GridLayoutBath
        cols: 1
        RelativeLayout:
            id: RelLayout
            Image:
                id: bathCreateImage
                size: self.parent.size
        GridLayout:
            rows:2
            Button:
                font_size: '40sp'
                size_hint: 1, None
                size: self.texture_size
                text: 'Cancel'
                on_release: root.dismiss()
            Button:
                font_size: '40sp'
                size_hint: 1, None
                size: self.texture_size
                text: 'Load'
                on_release: 
                    root.createBathFileChoosen()
                    root.dismiss()
                    app.root.current = 'loadingVideoScreen'
<LevelPopup>:
    title: 'Choose a water level value'
    title_size: '20dp'
    size_hint: None, None
    size: 500, 200
    auto_dismiss: False
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        TextInput:
            id: levelID
            multiline: False
            hint_text: 'water level'
        GridLayout:
            cols: 2
            size_hint_y: None
            height: self.parent.height*(1/3)
            padding: ['10sp', '5sp', '10sp', '5sp']
            spacing: '20sp'
            Button:
                font_size: '20sp'
                text: 'Cancel'
                on_release: root.dismiss()
            Button:
                text: 'Load'
                font_size: '20sp'
                on_release: 
                    if (levelID.text ==''): p = Factory.WaterLevelNotFound(); p.open()
                    else: root.registerLevel(); root.dismiss(); app.root.current = 'MaskAndROIScreen'  
                    
<LengthPopup>:
    title: 'Choose a river length value'
    title_size: '20dp'
    size_hint: None, None
    size: 500, 200
    auto_dismiss: False
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        TextInput:
            id: lengthID
            multiline: False
            hint_text: 'river length [m]'
        GridLayout:
            cols: 2
            size_hint_y: None
            height: self.parent.height*(1/3)
            padding: ['10sp', '5sp', '10sp', '5sp']
            spacing: '20sp'
            Button:
                font_size: '20sp'
                text: 'Cancel'
                on_release: root.dismiss()
            Button:
                text: 'Load'
                font_size: '20sp'
                on_release: 
                    if (lengthID.text ==''): p = Factory.ValueNotFound(); p.open()
                    else: root.registerLevel(); root.dismiss(); app.root.current = 'MaskAndROIScreen' 
                                      
<WaterLevelNotFound>
    title: 'Water level not found'
    title_size: '20dp'
    size_hint: None, None
    size: 400, 300
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        GridLayout:
            size_hint_y: None
            height: self.parent.height*0.6
            cols:1
            Label: 
                text: 'You did not write any value for the water level.'
        Button:
            size_hint_y: None
            height: self.parent.height*0.4
            text: 'Try again'
            on_release: 
                root.dismiss()                    
<DEMPopup>:
    title: 'Set parameters for loading DEM file'
    GridLayout:
        cols:1
        FileChooserListView:
            id: filechooser
            path: os.getcwd() + '/DEM'

        GridLayout:
            cols:2
            size_hint_y: None
            height: self.parent.height*0.3
            Label:
                text: 'Domain of DEM'
            TextInput:
                id: DomainID
                hint_text: 'e.g. : -1,2\n         -1,2'
            Label:
                text: 'Precision of DEM in mm/pixel'
            TextInput:
                id: PrecisionID
                hint_text: 'e.g. : 1'
            Label:
                text: 'Distance up to compare in m'
            TextInput:
                id: DistanceID
                hint_text: 'e.g. : 1'
        Button:
            size_hint_y: None
            height: self.parent.height*0.2
            text: 'Cancel'
            on_release: root.dismiss()
        Button:
            size_hint_y: None
            height: self.parent.height*0.2
            text: 'Load'
            # on_release: print('ok')
            on_release: 
                if (not filechooser.selection): p=Factory.FileNotFound();p.open()
                elif (DomainID.text ==''): p=Factory.ValueNotFound();p.open()
                elif (PrecisionID.text ==''): p=Factory.ValueNotFound();p.open()
                elif (DistanceID.text ==''): p=Factory.ValueNotFound();p.open()
                else : root.dismiss(); root.showBathPlot(filechooser.selection); app.root.current = 'DEMScreen'

<ComputeLevelPopup>:
    title: 'RESULT ALTERNATIVE METHODS'
    title_size: '20dp'
    size_hint: None, None
    size:  700, 700
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        BoxLayout:
            id: intersectionGraphID
        GridLayout:
            size_hint_y: None
            height: self.parent.height*0.1
            cols:2
            Label: 
                id: resultL
                text: ''
            Label:
                id: resultwl
                text: ''
        Button:
            size_hint_y: None
            height: self.parent.height*0.1
            text: 'Cancel'
            on_release: root.dismiss()
        Button:
            size_hint_y: None
            height: self.parent.height*0.1
            text: 'Load'
            on_release: 
                root.dismiss()
                app.root.current = 'MaskAndROIScreen'
<LengthNotFound>
    title: 'RESULT ALTERNATIVE METHODS'
    title_size: '20dp'
    size_hint: None, None
    size: 400, 300
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        GridLayout:
            size_hint_y: None
            height: self.parent.height*0.6
            cols:1
            Label: 
                text: 'Length chosen not found in the section. \n Please, try to select other points.'
        Button:
            size_hint_y: None
            height: self.parent.height*0.4
            text: 'Select new points'
            on_release: 
                root.dismiss()
                app.root.current = 'WaterLevelOrthoScreen'

<IntensityHighPassPopup>:
    title: 'Intensity High Pass Parameters'
    title_size: '20dp'
    size_hint: None, None
    size: 500, 300
    auto_dismiss: False
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        GridLayout:
            cols:2
            Label:
                text: 'Amplification factor: '
            TextInput:
                id: AmpliFactorID
                multiline: False
                text: '%.2f' % root.findParamHighPass()
            Label:
                text: 'Kernel Size (odd): '
            TextInput:
                id: kernelSizeID
                multiline: False
                text: '101,101'
            Label:
                text: 'Kernel SD  along X-axis: '
            TextInput:
                id: kernelStdXID
                multiline: False
                text: '0'
            Label:
                text: 'Kernel SD along Y-axis: '
            TextInput:
                id: kernelStdYID
                multiline: False
                text: '0'
        GridLayout:
            cols: 2
            size_hint_y: None
            height: self.parent.height*(1/4)
            Button:
                font_size: '20sp'
                text: 'Cancel'
                on_release: root.dismiss()
            Button:
                font_size: '20sp'
                text: 'Load'
                on_release: 
                    root.selectFilter('Intensity high-pass',float(AmpliFactorID.text),tuple([int(elt) for elt in kernelSizeID.text.split(',')]),int(kernelStdXID.text),int(kernelStdYID.text))
                    root.dismiss()

<IntensityCappingPopup>:
    title: 'Intensity Capping Parameters'
    title_size: '20dp'
