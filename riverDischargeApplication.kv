<WaterLevelOrtho>:
    name: 'WaterLevelOrthoScreen'
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        canvas.before:
            Color:
                rgba: 51/255, 51/255, 61/255, 1
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: 'Water level from orthorectified image'
            font_size: '50sp'
            size_hint_y: None
            size: 0, root.size[1]/9
            canvas.before:
                Color:
                    rgba: 0,0,0,1
                Rectangle:
                    pos: self.pos
                    size: self.size
        BoxLayout:
            id: RectifiefGraphID
        GridLayout:
            cols:6
            size_hint_y: None
            height: self.parent.height*(1/10)
            Button:
                text: 'Go back'
                on_release: 
                    app.root.current = 'waterLevelScreen'
            Button:
                
                text: 'Section Points'
                on_release:
                    root.selectSectPoints()
    
            Button:
                text: 'Register'
                on_release: 
                    root.saveInformation()
            Button:
                text: 'Load'
                on_release: 
                    [L,wl,xcs,ycs] = root.RiverLength()
                    if (wl==[-100000]): p = Factory.LengthNotFound();p.open()
                    elif(wl!=[-100000]): p = Factory.ComputeLevelPopup();p.setGraphIntersection(xcs,ycs);p.ids.resultL.text = 'Computed River Width : '+ str('%.3f' % L) + ' m';p.ids.resultwl.text = 'Computed Water Level : '+ str('%.3f' % wl) + ' m';p.open()

<WaterLevelDEM>:
    name: 'DEMScreen'
    BoxLayout:
        orientation: 'vertical'
        padding: [0,0,0,'10sp']
        canvas.before:
            Color:
                rgba: 51/255, 51/255, 61/255, 1
