<BathymetryCreate>:
    name: 'bathCreateScreen'
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: 51/255, 51/255, 61/255, 1
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: 'Create Bathymetry File'
            font_size: '50sp'
            size_hint_y: None
            size: 0, root.size[1]/9
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
        GridLayout:
            cols: 2
            spacing: '30sp'
            padding: ['20sp','20sp','20sp','10sp']
            BoxLayout:
                orientation: 'vertical'
                Image:
                    source: 'sections/img/rectOrig.png'
                    size: self.parent.size
                Button:
                    font_size: '30sp'
                    size_hint: 1, None
                    text: 'Rectangular'
                    size: self.texture_size
                    on_release: 
                        p = Factory.CreateBathPopup()
                        p.ids.bathCreateImage.source = 'sections/img/rectOrig.png'
                        p.RectTextInput()
                        p.open()

            BoxLayout:
                orientation: 'vertical'
                Image:
                    source: 'sections/img/trapOrig.png'
                    size: self.parent.size
                Button:
                    font_size: '30sp'
                    size_hint: 1, None
                    text: 'Trapezoidal'
                    size: self.texture_size
                    on_release: 
                        p = Factory.CreateBathPopup()
                        p.ids.bathCreateImage.source = 'sections/img/trapOrig.png'
                        p.TrapTextInput()
                        p.open()
        GridLayout:
            cols: 2
            spacing: '30sp'
            padding: ['20sp','10sp','20sp','20sp']
            BoxLayout:
                orientation: 'vertical'
                Image:
                    source: 'sections/img/parabOrig.png'
                    size: self.parent.size
                Button:
                    font_size: '30sp'
                    size_hint: 1, None
                    # pos_hint: {'top': 0.5}
                    text: 'Parabolic'
                    size: self.texture_size
                    on_release: 
                        p = Factory.CreateBathPopup()
                        p.ids.bathCreateImage.source = "sections/img/parabOrig.png"
                        p.ParabTextInput()
                        p.open()
            BoxLayout:
                orientation: 'vertical'
                Image:
                    source: 'sections/img/freeShape.png'
                    size: self.parent.size
                Button:
                    font_size: '30sp'
                    size_hint: 1, None
                    # pos_hint: {'bottom': 1}
                    text: 'Free Shape'
                    size: self.texture_size
                    on_release: 
                        p = Factory.CreateBathPopup()
                        p.ids.bathCreateImage.source = 'sections/img/freeShape.png'
                        p.FreeShapeTextInput()
                        p.open()
        Button:
            font_size: '20sp'
            size_hint: None, None
            pos: root.pos[0]+root.size[0]/2 - self.size[0]/2, root.pos[1]+ self.size[1]/3
            text: 'Go back'
            size: self.texture_size[0]*1.3,self.texture_size[1]*1.3
            on_release: 
                app.root.current = 'bathStartScreen'

<LoadingVideo>:
    name: 'loadingVideoScreen'
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        canvas.before:
            Color:
                rgba: 51/255, 51/255, 61/255, 1
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: 'Loading river flow video'
            font_size: '50sp'
            size_hint_y: None
            size: 0, root.size[1]/9
            canvas.before:
                Color:
                    rgba: 0,0,0,1
                Rectangle:
                    pos: self.pos
                    size: self.size
        FileChooserListView:
            id: videoRiver
            on_selection: endTimeID.text = root.showDuration(videoRiver.selection)
            path: os.getcwd() + '/mov'
        GridLayout:
            cols:2
            size_hint_y: None
            height: root.size[1]/12
            Label:
                text: 'Step betweeen frames: '
                font_size: '20sp'
            TextInput:
                id: stepID
                text: '1'
        GridLayout:
            cols:4
            size_hint_y: None
            padding: ['0sp', '10sp','10sp','0sp']
            height: root.size[1]/10
            Label:
                text: 'Range of video in\n seconds from'
                font_size: '20sp'
            TextInput:
                id: startTimeID
                text: '0'
            Label:
                text: 'to'
                font_size: '20sp'
            TextInput:
                id: endTimeID
                text: '0'
        GridLayout:
            cols:2
            size_hint_y: None
            height: root.size[1]/10
            Label:
                text: 'Stabilization for video'
                font_size: '20sp'
            Switch:
                id: switchStab
        GridLayout:
            cols:2
            padding: ['0sp', '0sp', '0sp', '10sp']
            size_hint_y: None
            height: root.size[1]/4
            Label:
                font_size: '20sp'
                text: '[u]Rules for stabilization:[/u]\nPress enter after each control point\nPress c to undo\nPress esc to launch stabilization'
                markup: True
                color: 0,0,0,1
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Line:
                        width: 2
                        rectangle: self.center_x-self.texture_size[0]*1.1/2, self.center_y-self.texture_size[1]*1.1/2, self.texture_size[0]*1.1, self.texture_size[1]*1.1
            Image:
                source: 'image/reperes.png'
        GridLayout:
            cols:2
            size_hint_y: None
            height: root.size[1]/10
            Button:
                text: 'Go back'
                on_release: 
                    app.root.current = 'bathStartScreen'
            Button:

                text: 'Load'
                on_release:
                    if (not videoRiver.selection) : p = Factory.FileNotFound(); p.open()  
                    elif switchStab.active : root.stabilizationPart(videoRiver.selection,float(startTimeID.text),float(endTimeID.text),int(stepID.text)); app.root.current = 'calibrationScreen' 
                    else : root.registerVideoRiverPath(videoRiver.selection,float(startTimeID.text),float(endTimeID.text),int(stepID.text)); app.root.current = 'calibrationScreen'
                    
<Calibration>:
    name: 'calibrationScreen'
    BoxLayout:
        orientation: 'vertical'
        padding: [0,0,0,'10sp']
        canvas.before:
            Color:
                rgba: 51/255, 51/255, 61/255, 1
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: 'Calibration of the camera'
            font_size: '50sp'
            size_hint_y: None
            size: 0, root.size[1]/9
            canvas.before:
                Color:
                    rgba: 0,0,0,1
                Rectangle:
                    pos: self.pos
                    size: self.size
        BoxLayout:
            spacing: '28sp'
            padding: [0,'60sp',0,'70sp']
            orientation: 'vertical'
            CustomButton:
                text: 'Go back'
                pos_hint: {'center_x': 0.5}
                size_hint: 0.5,0.2
                font_size: '30sp'
                on_release: 
                    app.root.current = 'loadingVideoScreen'
            CustomButton:
                text: 'Load file'
                pos_hint: {'center_x': 0.5}
                size_hint: 0.5,0.2
                font_size: '30sp'
                on_release: 
                    p = Factory.LoadFileCalibPopup(loadFile=root.loadFile)
                    p.open()
            CustomButton:
                text: 'Perform calibration'
                pos_hint: {'center_x': 0.5}
                size_hint: 0.5,0.2
                font_size: '30sp'
                on_release: 
                    p = Factory.ComputationCalibPopup(computeCalib=root.computeCalib)
                    p.open()
            CustomButton:
                text: 'Compute parameters'
                pos_hint: {'center_x': 0.5}
                size_hint: 0.5,0.2
                font_size: '30sp'
                on_release:
                    p = Factory.LoadingParamCalibPopup(loadParam=root.loadParam)
                    p.open()
            CustomButton:
                text: 'Skip this step'
                pos_hint: {'center_x': 0.5}
                size_hint: 0.5,0.2
                font_size: '30sp'
                on_release: 
                    app.root.current = 'OrthoRectificationScreen'

<OrthoRectification>:
    name: 'OrthoRectificationScreen'
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        canvas.before:
            Color:
                rgba: 51/255, 51/255, 61/255, 1
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: 'Orthorectification'
            font_size: '50sp'
            size_hint_y: None
            size: 0, root.size[1]/9
            canvas.before:
                Color:
                    rgba: 0,0,0,1
                Rectangle:
                    pos: self.pos
                    size: self.size
        BoxLayout:
            id: OrthoGraphID
        GridLayout:
            cols:7
            size_hint_y: None
            height: self.parent.height*(1/10)
            Button:
                text: 'Go back'
                on_release: 
                    app.root.current = 'calibrationScreen'
            Button:
                # id: ROI
                text: 'Select Ref Points'
                on_release:
                    root.selectSrcPoints()
            Button:
                id: DistID
                text: 'Set real dist'
                on_release:
                    p = Factory.LoadingDistOrthoPopup(SetRealDistances=root.SetRealDistances)
                    p.open()
            Button:
                text: 'Apply Mask'
                on_release: 
                    root.selectMask()
            Button:
                text: 'Register'
                on_release: 
                    root.registerInformation()
            Button:
                text: 'Load'
                on_release: 
                    root.LoadPts()
                    if (app.ORTHOPARAMS['pts_src']==[]):p = Factory.OrthoParamNotFound();p.open() 
                    elif (app.ORTHOPARAMS['pts_mask']==[]): p = Factory.OrthoParamNotFound();p.open()
                    else : app.root.current = 'waterLevelScreen'   
                    #app.root.current = 'waterLevelScreen'
            Button:
                text: 'Skip this step'
                on_release: 
                    app.root.current = 'waterLevelScreen'
<OrthoParamNotFound>
    title: 'Parameters of orthorectification'
    title_size: '20dp'
    size_hint: None, None
