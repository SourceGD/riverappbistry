<WaterLevelComputation>:
    name: 'waterLevelDrone'
    GridLayout:
        cols:1
        col_force_default: True
        col_default_width: self.parent.width
        canvas.before:
            Color:
                rgba: 51/255, 51/255, 61/255, 1
            Rectangle:
                pos: self.pos
                size: self.size
        GridLayout:
            cols:2
            Label:
                size_hint_y: None
                height: self.parent.height*(1/10)
                text: 'Select image at the lower altitude'
                font_size: '18sp'
                canvas.before:
                    Color:
                        rgba: 0,0,0,1
                    Rectangle:
                        pos: self.pos
                        size: self.size
            Label:
                size_hint_y: None
                height: self.parent.height*(1/10)
                text: 'Select image at the higher altitude'
                font_size: '18sp'
                canvas.before:
                    Color:
                        rgba: 0,0,0,1
                    Rectangle:
                        pos: self.pos
                        size: self.size
            FileChooserListView:
                id: closeImage
                path: os.getcwd() + '/img'
            FileChooserListView:
                id: farImage
                path: os.getcwd() + '/img'
        GridLayout:
            cols:2
            size_hint_y: None
            height: self.parent.height*(1/10)
            Label:
                text: 'Delta of height between the two pictures in meter:'
            TextInput:
                id: deltaH
                hint_text: 'e.g. : 1'
        Button:
            size_hint_y: None
            height: self.parent.height*(1/10)
            text: 'Go back'
            on_release: 
                app.root.current = 'waterLevelScreen'
        Button:
            size_hint_y: None
            height: self.parent.height*(1/10)
            text: 'LOAD'
            on_release: 
                [L,wl,xcs,ycs] = root.RiverLength(closeImage.selection, farImage.selection, float(deltaH.text))
                if (wl==[-100000]): p = Factory.LengthNotFoundCalib(); p.open()
                elif(wl!=[-100000]): p = Factory.ComputeLevelPopup(); p.setGraphIntersection(xcs,ycs); p.ids.resultL.text = 'Computed River Width : '+ str('%.3f' % L) + ' m';p.ids.resultwl.text = 'Computed Water Level : '+ str('%.3f' % wl) + ' m';p.open()
                
