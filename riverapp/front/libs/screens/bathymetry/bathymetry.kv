#:kivy 2.2.0

#:include libs/components/app_bar/main_app_bar/main_app_bar.kv
#:include libs/components/app_bar/screen_title/screen_title.kv
#:import TextUnderIconButton libs.components.widget.text_under_icon_button.text_under_icon_button.TextUnderIconButton

<BathymetryMobileView>:
    name: "bathymetry_mobile_view"

    MDBoxLayout:
        orientation: "vertical"

        MainAppBar:

        ScreenTitle:
            title: "Bathymetry - Configuration"
            left_action_items: [["arrow-left", lambda x: app.root.ids.screen_manager.get_screen("bathymetry").go_back()]]
            
        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: root.height - 2 * dp(64) #dp(64) = MDTopAppBar height
            
            MDBoxLayout:
                id: content

                MDBoxLayout:
                    id: upload_button
                    # Empty FloatLayout because if button is alone in a Layout the width strech to maximum
                    MDFloatLayout:
                        size_hint: 0.2, 1

                    TextUnderIconButton:
                        size_hint: 1, 0.5
                        pos_hint: {"center_x": 0.5, "center_y": 0.5}
                        icon: "upload"
                        icon_size: "64sp"
                        text: "Upload Bathymetry"
                        on_release: app.root.ids.screen_manager.get_screen("bathymetry").open_file_manager()
                        
                    # Empty FloatLayout because if button is alone in a Layout the width stech to maximum
                    MDFloatLayout:
                        size_hint: 0.2, 1

            MDBoxLayout:
                id: control_button
                padding: dp(10)
                spacing: dp(10)
                adaptive_size: True
                pos_hint: {"center_y": 0.5, "right": 1}
                disabled: True
                opacity: 0 if self.disabled else 1

                MDFillRoundFlatButton:
                    text: "Change Bathymetry"
                    font_style: "Button"
                    disabled: root.disabled
                    md_bg_color: app.theme_cls.error_color
                    on_release: app.root.ids.screen_manager.get_screen("bathymetry").remove_graph()

                MDFillRoundFlatButton:

                    text: "Validate"
                    font_style: "Button"
                    disabled: root.disabled
                    on_release: app.root.ids.screen_manager.get_screen("bathymetry").send_bathymetry()

