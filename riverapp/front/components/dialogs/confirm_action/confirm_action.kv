#:kivy 2.2.0
#:import Factory kivy.factory.Factory

<ConfirmAction>:
    title: root.title
    text: root.text
    buttons: 
        [ \
        Factory.MDRoundFlatButton(text=root.cancel_text, on_release=root.dismiss), \
        Factory.MDFillRoundFlatButton(text=root.confirm_text, on_release=root.confirm_callback) \
        ]

                    
    
        
        
    